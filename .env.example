# Local-only demo configuration (no external network calls)

# Streamlit demo data directory (default: app/demo_data)
DEMO_DATA_DIR=app/demo_data

# Optional: preferred golden run directory (created by scripts/freeze_artifacts.py)
# GOLDEN_RUN_DIR=analysis/artifacts/golden_run_YYYYMMDD

# Ollama host (local). Used only if available; demo has fallback.
OLLAMA_HOST=http://localhost:11434

# Paper sources directory for RAG ingestion (user-provided PDFs/txt)
RAG_SOURCES_DIR=rag/sources

